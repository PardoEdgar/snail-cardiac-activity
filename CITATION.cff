cff-version: 1.2.0
title: "Cardiovascular adjustments during experimentally induced retraction and locomotion in the invasive terrestrial snail Cornu aspersum (Müller, 1774)"
message: "If you use this dataset or workflow, please cite it as below."
type: dataset

authors:
  - family-names: "Pardo-Sarmiento"
    given-names: "Edgar Alejandro"
  - family-names: "Hernandez"
    given-names: "Juan Pablo"
  - family-names: "Buitrago-Ricaurte"
    given-names: "Natalia"
  - family-names: "Riveros"
